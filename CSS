body { font-family: sans-serif; display: flex; justify-content: center; background: #f4f7f6; height: 100vh; }
.todo-container { background: white; padding: 20px; border-radius: 10px; margin-top: 50px; }
li { padding: 10px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; cursor: pointer; }
li.completed { text-decoration: line-through; color: #888; }
.delete-btn { background: #dc3545; color: white; border: none; padding: 5px; cursor: pointer; }
